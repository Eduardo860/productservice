<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Properties>
        <Property name="LOG_PATTERN">%d{HH:mm:ss} %-5level %logger{36} - %msg%n</Property>
        <Property name="APP_NAME">productservice</Property>
        <Property name="LOG_GROUP_NAME">producto-log-group</Property>
        <Property name="LOG_STREAM_NAME">producto-service-stream</Property>
    </Properties>

    <Appenders>
        <!-- Console Appender -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}" />
        </Console>

        <!-- CloudWatch Appender -->
        <CloudWatchLogs name="CloudWatch">
            <PatternLayout pattern="${LOG_PATTERN}" />
            <logGroupName>${LOG_GROUP_NAME}</logGroupName>
            <logStreamName>${LOG_STREAM_NAME}</logStreamName>
            <region>us-east-1</region>
            <endpoint>${env:CLOUDWATCH_ENDPOINT:-}</endpoint>
            <createLogGroup>false</createLogGroup>
            <queueLength>1000</queueLength>
            <blockWhenQueueFull>false</blockWhenQueueFull>
        </CloudWatchLogs>
    </Appenders>

    <Loggers>
        <!-- Root Logger -->
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="CloudWatch"/>
        </Root>

        <!-- Spring Framework Logging -->
        <Logger name="org.springframework" level="info" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="CloudWatch"/>
        </Logger>

        <!-- Application Logging -->
        <Logger name="com.microservices.productservice" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="CloudWatch"/>
        </Logger>
    </Loggers>
</Configuration>
